[gd_scene load_steps=2 format=3 uid="uid://wys_creds"]

[ext_resource type="Script" path="res://CredentialsDialog.cs" id="1_creds"]

[node name="CredentialsDialog" type="Window"]
script = ExtResource("1_creds")
title = "Steam Login Required"
size = Vector2i(400, 230)
visible = false
exclusive = true
always_on_top = true
wrap_controls = true

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_top = 14
theme_override_constants/margin_bottom = 14

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="InfoLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
size_flags_horizontal = 3
autowrap_mode = 3
text = "Steam credentials are required to download the base game sandbox files. Your credentials are used only once and are never stored."
theme_override_colors/font_color = Color(0.7, 0.7, 0.7, 1)

[node name="UserRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="UserLabel" type="Label" parent="Margin/VBox/UserRow"]
layout_mode = 2
custom_minimum_size = Vector2(90, 0)
vertical_alignment = 1
text = "Username:"

[node name="UserEdit" type="LineEdit" parent="Margin/VBox/UserRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Steam username"

[node name="PassRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="PassLabel" type="Label" parent="Margin/VBox/PassRow"]
layout_mode = 2
custom_minimum_size = Vector2(90, 0)
vertical_alignment = 1
text = "Password:"

[node name="PassEdit" type="LineEdit" parent="Margin/VBox/PassRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Steam password"
secret = true

[node name="ErrorLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = ""
theme_override_colors/font_color = Color(0.95, 0.35, 0.35, 1)
theme_override_font_sizes/font_size = 12

[node name="BtnRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
