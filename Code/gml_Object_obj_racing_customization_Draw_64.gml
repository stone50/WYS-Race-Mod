draw_text_transformed(360, 438.75, "Name\nScale", 0.5, 0.5, 0);
draw_slider(360, 506.25, other_racer_names_scale);
draw_text_transformed(720, 67.5, "Player", 1, 1, 0);
draw_set_color((gui_mouse_x >= 500 && gui_mouse_x <= 700 && gui_mouse_y >= 152.5 && gui_mouse_y <= 252.5) ? c_purple : c_dkgray);
draw_roundrect(500, 152.5, 700, 252.5, false);
draw_set_color(c_white);
draw_text_transformed(600, 202.5, "Edit Name", 0.5, 0.5, 0);
