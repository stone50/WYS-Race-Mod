draw_color_grid(600, 371.25, outline_colors);
draw_text_transformed(840, 303.75, "Body\nColor", 0.5, 0.5, 0);
draw_color_grid(840, 371.25, body_colors);
draw_text_transformed(600, 438.75, "Shell\nColor", 0.5, 0.5, 0);
